    <!-- Integrations -->
    <section class="integrations-section" style="z-index: 10;">
      <div class="integrations-header">
        <div class="integrations-eyebrow">Integrations</div>
        <h2 class="integrations-title">Part of the AI development stack</h2>
        <p class="integrations-sub">SimCast is designed to work alongside the tools AI agents already use to build and automate iOS apps.</p>
      </div>

      <div class="integrations-grid">

        <!-- XcodeBuildMCP -->
        <div class="integration-card">
          <div class="integration-banner">
            <img src="https://github.com/getsentry/XcodeBuildMCP/raw/main/assets/banner.png" alt="XcodeBuildMCP — MCP server for Xcode build automation by Sentry" loading="lazy" />
          </div>
          <div class="integration-body">
            <div class="integration-meta">
              <span class="integration-tag">MCP Server</span>
              <span class="integration-tag">by Sentry</span>
            </div>
            <h3 class="integration-name">XcodeBuildMCP</h3>
            <p class="integration-desc">An MCP server that gives AI agents direct access to Xcode — build, install, launch, and test iOS apps in the Simulator without leaving the agent loop. Pair it with SimCast so your agent can build the app <em>and</em> watch it run.</p>
            <div class="integration-workflow">
              <div class="workflow-step">
                <span class="workflow-num">1</span>
                <span>Agent builds &amp; installs via XcodeBuildMCP</span>
              </div>
              <div class="workflow-step">
                <span class="workflow-num">2</span>
                <span>SimCast streams the live Simulator window</span>
              </div>
              <div class="workflow-step">
                <span class="workflow-num">3</span>
                <span>Agent observes, taps, and iterates</span>
              </div>
            </div>
            <a href="https://github.com/getsentry/XcodeBuildMCP" class="integration-link" target="_blank" rel="noopener">
              View on GitHub
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" width="12" height="12"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
            </a>
          </div>
        </div>

        <!-- AXe -->
        <div class="integration-card integration-card--required">
          <div class="integration-banner">
            <img src="https://github.com/cameroncooke/AXe/raw/main/banner.png" alt="AXe — CLI tool for iOS Simulator touch injection by Cameron Cooke" loading="lazy" />
          </div>
          <div class="integration-body">
            <div class="integration-meta">
              <span class="integration-tag integration-tag--required">
                <svg viewBox="0 0 12 12" fill="currentColor" width="9" height="9"><path d="M6 1a5 5 0 100 10A5 5 0 006 1zm.5 7.5h-1v-1h1v1zm0-2h-1V3.5h1V6.5z"/></svg>
                Required
              </span>
              <span class="integration-tag">CLI Tool</span>
              <span class="integration-tag">by Cameron Cooke</span>
            </div>
            <h3 class="integration-name">AXe</h3>
            <p class="integration-desc">SimCast depends on AXe to translate remote interactions into real Simulator events. Install it with Homebrew and SimCast picks it up automatically — taps, gestures, hardware buttons, and text input all flow through it.</p>
            <div class="integration-workflow">
              <div class="workflow-step">
                <span class="workflow-num">1</span>
                <span>Web client sends tap via LiveKit data channel</span>
              </div>
              <div class="workflow-step">
                <span class="workflow-num">2</span>
                <span>SimCast macOS app receives the event</span>
              </div>
              <div class="workflow-step">
                <span class="workflow-num">3</span>
                <span>AXe injects it into the Simulator as a real touch</span>
              </div>
            </div>
            <a href="https://github.com/cameroncooke/AXe" class="integration-link" target="_blank" rel="noopener">
              View on GitHub
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" width="12" height="12"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
            </a>
          </div>
        </div>

      </div>
    </section>

