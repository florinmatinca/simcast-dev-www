---
import Layout from "../layouts/Layout.astro";

const GITHUB_URL = "https://github.com/simcast-dev/simcast";

const features = [
  {
    title: "Instant browser access",
    desc: "Anyone with a link can see and control your Simulator — no installs, no plugins, no screen sharing needed.",
    icon: `<svg viewBox="0 0 20 20" fill="currentColor" width="20" height="20"><path fill-rule="evenodd" d="M4.25 2A2.25 2.25 0 002 4.25v11.5A2.25 2.25 0 004.25 18h11.5A2.25 2.25 0 0018 15.75V4.25A2.25 2.25 0 0015.75 2H4.25zm4.03 6.28a.75.75 0 00-1.06-1.06L4.97 9.47a.75.75 0 000 1.06l2.25 2.25a.75.75 0 001.06-1.06L6.56 10l1.72-1.72zm3.44-1.06a.75.75 0 10-1.06 1.06L12.44 10l-1.72 1.72a.75.75 0 101.06 1.06l2.25-2.25a.75.75 0 000-1.06l-2.25-2.25z" clip-rule="evenodd" /></svg>`,
  },
  {
    title: "Real touch & gestures",
    desc: "Tap, swipe, scroll, and long-press — interact with the app like you're holding the device, powered by native accessibility APIs.",
    icon: `<svg viewBox="0 0 20 20" fill="currentColor" width="20" height="20"><path fill-rule="evenodd" d="M6.672 1.911a1 1 0 10-1.932.518l.259.966a1 1 0 001.932-.518l-.26-.966zM2.429 4.74a1 1 0 10-.517 1.932l.966.259a1 1 0 00.517-1.932l-.966-.26zm8.814-.569a1 1 0 00-1.415-1.414l-.707.707a1 1 0 101.415 1.415l.707-.708zm-7.071 7.072l.707-.707A1 1 0 003.465 9.12l-.708.707a1 1 0 101.415 1.415zm3.2-5.171a1 1 0 00-1.3 1.3l4 10a1 1 0 001.823.075l1.38-2.759 3.018 3.02a1 1 0 001.414-1.415l-3.019-3.02 2.76-1.379a1 1 0 00-.076-1.822l-10-4z" clip-rule="evenodd" /></svg>`,
  },
  {
    title: "Full device control",
    desc: "Type text, press Home, Lock, or Side buttons, and open deep links — everything you'd do locally, from anywhere.",
    icon: `<svg viewBox="0 0 20 20" fill="currentColor" width="20" height="20"><path d="M3.25 4A2.25 2.25 0 001 6.25v7.5A2.25 2.25 0 003.25 16h7.5A2.25 2.25 0 0013 13.75v-7.5A2.25 2.25 0 0010.75 4h-7.5zM19 4.75a.75.75 0 00-1.28-.53l-3 3a.75.75 0 00-.22.53v4.5c0 .199.079.39.22.53l3 3a.75.75 0 001.28-.53V4.75z" /></svg>`,
  },
  {
    title: "Multi-simulator",
    desc: "Stream multiple simulators at once — QA across devices in parallel from a single dashboard.",
    icon: `<svg viewBox="0 0 20 20" fill="currentColor" width="20" height="20"><path d="M2 4.5A2.5 2.5 0 014.5 2h11A2.5 2.5 0 0118 4.5v3a2.5 2.5 0 01-2.5 2.5h-11A2.5 2.5 0 012 7.5v-3zM2 12.5A2.5 2.5 0 014.5 10h4a2.5 2.5 0 012.5 2.5V14a2.5 2.5 0 01-2.5 2.5h-4A2.5 2.5 0 012 14v-1.5zM13 12.5A2.5 2.5 0 0115.5 10H16a2.5 2.5 0 012.5 2.5V14A2.5 2.5 0 0116 16.5h-.5A2.5 2.5 0 0113 14v-1.5z" /></svg>`,
  },
  {
    title: "Window-level capture",
    desc: "Only the Simulator window is captured — no desktop, no distractions, no accidental screen shares.",
    icon: `<svg viewBox="0 0 20 20" fill="currentColor" width="20" height="20"><path fill-rule="evenodd" d="M2 4.25A2.25 2.25 0 014.25 2h11.5A2.25 2.25 0 0118 4.25v8.5A2.25 2.25 0 0115.75 15H13.5v1.25a.75.75 0 01-.75.75H7.25a.75.75 0 01-.75-.75V15H4.25A2.25 2.25 0 012 12.75v-8.5z" clip-rule="evenodd" /></svg>`,
  },
  {
    title: "Open source & self-hosted",
    desc: "MIT licensed. Runs on your infrastructure — no third-party accounts, no usage limits, no data leaving your network.",
    icon: `<svg viewBox="0 0 20 20" fill="currentColor" width="20" height="20"><path fill-rule="evenodd" d="M4.5 2A1.5 1.5 0 003 3.5v13A1.5 1.5 0 004.5 18h11a1.5 1.5 0 001.5-1.5V7.621a1.5 1.5 0 00-.44-1.06l-4.12-4.122A1.5 1.5 0 0011.378 2H4.5zm2.25 8.5a.75.75 0 000 1.5h6.5a.75.75 0 000-1.5h-6.5zm0 3a.75.75 0 000 1.5h6.5a.75.75 0 000-1.5h-6.5z" clip-rule="evenodd" /></svg>`,
  },
];

---

<Layout title="SimCast — Simulator Streaming" description="Stream Simulators live from your Mac to any browser, with real-time touch interaction over WebRTC.">
  <main style="background: var(--bg); color: var(--text); min-height: 100vh; overflow-x: hidden;">

    <!-- Gradient mesh — top bloom -->
    <div class="fixed inset-0 pointer-events-none gradient-mesh" style="z-index: 0;">
      <div class="absolute" style="top: -20%; left: 50%; transform: translateX(-50%); width: 900px; height: 700px; background: radial-gradient(ellipse at center, rgba(109,40,217,0.55) 0%, rgba(79,70,229,0.3) 30%, transparent 70%); filter: blur(1px);"></div>
      <div class="absolute animate-aurora-1" style="top: -5%; left: -10%; width: 700px; height: 600px; background: radial-gradient(ellipse at center, rgba(123,82,255,0.4) 0%, transparent 65%); filter: blur(40px);"></div>
      <div class="absolute animate-aurora-2" style="top: 0%; right: -5%; width: 600px; height: 500px; background: radial-gradient(ellipse at center, rgba(59,130,246,0.3) 0%, rgba(0,207,255,0.15) 40%, transparent 70%); filter: blur(50px);"></div>
      <div class="absolute" style="bottom: 0; left: 0; right: 0; height: 40%; background: linear-gradient(to top, var(--bg) 0%, transparent 100%);"></div>
      <div class="absolute inset-0" style="background-image: radial-gradient(circle, rgba(123,82,255,0.25) 1px, transparent 1px); background-size: 36px 36px; opacity: 0.35; mask-image: radial-gradient(ellipse 90% 60% at 50% 0%, black 0%, transparent 100%);"></div>
      <div class="absolute inset-0 bg-noise" style="opacity: 0.025;"></div>
    </div>

    <!-- Nav -->
    <nav class="nav" style="z-index: 10;">
      <div class="nav-brand">
        <div class="logo-icon">
          <img src="/SimCast.png" alt="SimCast" width="36" height="36" style="border-radius: 0.5rem;" />
        </div>
        <span class="logo-text">SimCast</span>
      </div>
      <div class="nav-links">
        <a href="https://github.com/simcast-dev/simcast/releases/tag/v1.0.4" class="nav-pill" rel="noopener noreferrer">Check out Release 1.0.4</a>
      </div>
    </nav>

    <!-- Hero -->
    <section class="hero" style="z-index: 10;">
      <div class="hero-grid">

        <!-- Left: copy -->
        <div class="hero-copy">
          <div class="animate-fade-in-up">
            <h1 class="headline">
              Stream any Simulator,{" "}
              <span class="headline-accent">anywhere.</span>
            </h1>
          </div>

          <p class="subtext animate-fade-in-up delay-200">
            Your Simulator, live in any browser.<br>See it, touch it, test it.
          </p>

          <div class="cta-row animate-fade-in-up delay-300">
            <a href={GITHUB_URL} class="cta-github">
              <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" /></svg>
              View on GitHub
            </a>
          </div>

        </div>

        <!-- Right: illustration -->
        <div class="hero-illustration animate-fade-in-up delay-300">
          <div class="illustration-wrapper animate-float">
            <!-- Outer ambient glow -->
            <div class="illustration-glow animate-glow-breathe"></div>

            <!-- Perspective wrapper -->
            <div style="perspective: 1100px;">
              <div style="transform: rotateX(4deg) rotateY(-10deg);" class="illustration-inner">
                <!-- Browser chrome -->
                <div class="browser-chrome">
                  <!-- Tab bar -->
                  <div class="tab-bar">
                    <div class="dot" style="background: #FF5F57;"></div>
                    <div class="dot" style="background: #FFBD2E;"></div>
                    <div class="dot" style="background: #28C840;"></div>
                    <div class="address-bar">
                      <div class="address-dot"></div>
                      <span class="address-text">simcast.dev/dashboard</span>
                    </div>
                  </div>

                  <!-- Page content — split layout -->
                  <div class="browser-content">
                    <!-- Left panel: simulator list -->
                    <div class="panel-left">
                      <div class="section-header">
                        <span class="section-title">ACTIVE SIMULATORS</span>
                        <span class="section-badge">3</span>
                        <div class="section-line"></div>
                        <span class="section-uptime">22m session</span>
                      </div>

                      <!-- Card 1 — watching -->
                      <div class="sim-card sim-card-active">
                        <div class="sim-card-top">
                          <div class="sim-icon-box">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="20" height="20" style="color: #7C3AED;">
                              <rect x="6" y="2" width="12" height="20" rx="2.5" />
                              <circle cx="12" cy="18.5" r="0.75" fill="currentColor" stroke="none" />
                              <line x1="6" y1="4.5" x2="18" y2="4.5" stroke-width="0.75" />
                            </svg>
                          </div>
                          <div class="sim-info">
                            <div class="sim-name-row">
                              <span class="sim-name">iPhone 17 Pro</span>
                              <span class="watching-badge">
                                <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" width="7" height="7"><path d="M1 8s2.5-5 7-5 7 5 7 5-2.5 5-7 5-7-5-7-5z" /><circle cx="8" cy="8" r="2" fill="currentColor" stroke="none" /></svg>
                                WATCHING
                              </span>
                            </div>
                            <p class="sim-os">iOS 26.2</p>
                            <p class="sim-udid">3A1F8B2C</p>
                          </div>
                        </div>
                        <div class="sim-card-footer">
                          <span class="sim-duration">Started 22m ago</span>
                          <div class="sim-actions">
                            <div class="sim-btn sim-btn-danger">
                              <svg viewBox="0 0 16 16" fill="currentColor" width="8" height="8"><rect x="3" y="3" width="10" height="10" rx="1" /></svg>
                              Stop
                            </div>
                          </div>
                        </div>
                      </div>

                      <!-- Card 2 — streaming -->
                      <div class="sim-card sim-card-streaming">
                        <div class="sim-card-top">
                          <div class="sim-icon-box">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="20" height="20" style="color: #7C3AED;">
                              <rect x="4" y="2" width="16" height="20" rx="2.5" />
                              <circle cx="12" cy="18.5" r="0.75" fill="currentColor" stroke="none" />
                              <line x1="4" y1="4.5" x2="20" y2="4.5" stroke-width="0.75" />
                            </svg>
                          </div>
                          <div class="sim-info">
                            <div class="sim-name-row">
                              <span class="sim-name">iPad Pro 13"</span>
                              <span class="streaming-badge">
                                <span class="streaming-dot"></span>
                                STREAMING
                              </span>
                            </div>
                            <p class="sim-os">iPadOS 26.1</p>
                            <p class="sim-udid">E7D04A9F</p>
                          </div>
                        </div>
                        <div class="sim-card-footer">
                          <span class="sim-duration">Started 14m ago</span>
                          <div class="sim-actions">
                            <span class="sim-watch-hint">
                              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" width="10" height="10"><path d="M1 8s2.5-5 7-5 7 5 7 5-2.5 5-7 5-7-5-7-5z" /><circle cx="8" cy="8" r="2" fill="currentColor" stroke="none" /></svg>
                              Tap to watch
                            </span>
                            <div class="sim-btn sim-btn-danger">
                              <svg viewBox="0 0 16 16" fill="currentColor" width="8" height="8"><rect x="3" y="3" width="10" height="10" rx="1" /></svg>
                              Stop
                            </div>
                          </div>
                        </div>
                      </div>

                      <!-- Card 3 — idle -->
                      <div class="sim-card sim-card-inactive">
                        <div class="sim-card-top">
                          <div class="sim-icon-box sim-icon-box-inactive">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="20" height="20" style="color: #8078a8;">
                              <rect x="6" y="2" width="12" height="20" rx="2.5" />
                              <circle cx="12" cy="18.5" r="0.75" fill="currentColor" stroke="none" />
                              <line x1="6" y1="4.5" x2="18" y2="4.5" stroke-width="0.75" />
                            </svg>
                          </div>
                          <div class="sim-info">
                            <div class="sim-name-row">
                              <span class="sim-name">iPhone 16</span>
                            </div>
                            <p class="sim-os">iOS 26.0</p>
                            <p class="sim-udid">B9C2E61D</p>
                          </div>
                        </div>
                        <div class="sim-card-footer">
                          <span class="sim-duration">Started 8m ago</span>
                          <div class="sim-actions">
                            <div class="sim-btn sim-btn-primary">
                              <svg viewBox="0 0 16 16" fill="currentColor" width="8" height="8"><path d="M3 3.732a1.5 1.5 0 012.305-1.265l6.706 4.267a1.5 1.5 0 010 2.531L5.305 13.533A1.5 1.5 0 013 12.267V3.732z" /></svg>
                              Start
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>

                    <!-- Right panel: video preview + buttons -->
                    <div class="panel-right">
                      <div class="viewer-row">
                        <!-- Phone frame -->
                        <div class="viewer-screen">
                          <div class="viewer-stream-bg"></div>
                          <div class="viewer-app-ui">
                            <div class="viewer-status-bar">
                              <span style="font-size: 5px; color: rgba(255,255,255,0.5);">9:41</span>
                              <div style="display: flex; gap: 2px; align-items: center;">
                                <div style="width: 8px; height: 4px; border-radius: 1px; border: 1px solid rgba(255,255,255,0.4);"><div style="width: 60%; height: 100%; background: rgba(255,255,255,0.4); border-radius: 0.5px;"></div></div>
                              </div>
                            </div>
                            <div class="viewer-nav-bar">
                              <div style="height: 4px; width: 50%; border-radius: 3px; background: rgba(255,255,255,0.25);"></div>
                            </div>
                            <div class="viewer-content-rows">
                              <div style="height: 14px; border-radius: 3px; background: rgba(255,255,255,0.06);"></div>
                              <div style="height: 4px; width: 80%; border-radius: 2px; background: rgba(255,255,255,0.12);"></div>
                              <div style="height: 4px; width: 60%; border-radius: 2px; background: rgba(255,255,255,0.08);"></div>
                              <div style="height: 20px; border-radius: 3px; background: rgba(255,255,255,0.05); margin-top: 2px;"></div>
                              <div style="height: 4px; width: 70%; border-radius: 2px; background: rgba(255,255,255,0.10);"></div>
                              <div style="height: 4px; width: 45%; border-radius: 2px; background: rgba(255,255,255,0.07);"></div>
                            </div>
                            <div class="viewer-tab-bar">
                              <div style="width: 6px; height: 6px; border-radius: 1.5px; background: rgba(255,255,255,0.12);"></div>
                              <div style="width: 6px; height: 6px; border-radius: 1.5px; background: rgba(124,58,237,0.4);"></div>
                              <div style="width: 6px; height: 6px; border-radius: 1.5px; background: rgba(255,255,255,0.12);"></div>
                              <div style="width: 6px; height: 6px; border-radius: 1.5px; background: rgba(255,255,255,0.12);"></div>
                            </div>
                          </div>
                          <div class="viewer-scanline animate-scanline" style="animation-delay: -1.5s;"></div>
                        </div>

                        <!-- Control buttons column -->
                        <div class="ctrl-buttons">
                          <div class="ctrl-btn"><svg viewBox="0 0 20 20" width="11" height="11" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="4" y="4" width="12" height="12" rx="3.5" /></svg></div>
                          <div class="ctrl-btn"><svg viewBox="0 0 20 20" width="11" height="11" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="10" cy="11" r="5" /><line x1="10" y1="2" x2="10" y2="6" stroke-linecap="round" /></svg></div>
                          <div class="ctrl-btn"><svg viewBox="0 0 20 20" width="11" height="11" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="8" y="3" width="4" height="14" rx="2" /></svg></div>
                          <div style="height: 6px;"></div>
                          <div class="ctrl-btn"><svg viewBox="0 0 14 16" width="11" height="12" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 7V3.5a1 1 0 0 1 2 0V7m0 0V4.5a1 1 0 0 1 2 0V7m0 0V5.5a1 1 0 0 1 2 0V9a5 5 0 0 1-5 5H4A3 3 0 0 1 1 11V7.5a1 1 0 0 1 2 0V7" /></svg></div>
                          <div class="ctrl-btn"><svg viewBox="0 0 12 14" width="10" height="11" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M6 1v12M3 4l3-3 3 3M3 10l3 3 3-3" /></svg></div>
                          <div class="ctrl-btn"><svg viewBox="0 0 12 12" width="10" height="10" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"><path d="M2 3h8M6 3v7M4 10h4" /></svg></div>
                        </div>
                      </div>
                      <!-- Viewer label -->
                      <div class="viewer-label">
                        <span class="viewer-label-name">iPhone 17 Pro</span>
                        <span class="viewer-label-latency">48ms</span>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Scan line -->
                <div class="scan-line animate-scanline"></div>
              </div>
            </div>

            <!-- Stacked devices on the left -->
            <div class="devices-stack animate-fade-in-up delay-400">
              <!-- Device 1 — iPhone (top) -->
              <div class="stacked-device stacked-device-top">
                <div class="iphone-frame">
                  <div class="iphone-island"></div>
                  <div class="iphone-screen">
                    <div class="iphone-stream-bg"></div>
                    <div class="iphone-stream-lines">
                      <div class="iphone-stream-line" style="width: 80%; opacity: 0.35;"></div>
                      <div class="iphone-stream-line" style="width: 65%; opacity: 0.25;"></div>
                      <div class="iphone-stream-line" style="width: 72%; opacity: 0.2;"></div>
                      <div class="iphone-stream-app-bar"></div>
                    </div>
                    <div class="iphone-scanline animate-scanline"></div>
                    <div class="iphone-live-badge">
                      <span class="iphone-live-dot"></span>
                      <span class="iphone-live-text">LIVE</span>
                    </div>
                    <div class="iphone-latency">42ms</div>
                  </div>
                  <div class="iphone-home-indicator"></div>
                </div>
              </div>

              <!-- Device 2 — iPhone (bottom) -->
              <div class="stacked-device stacked-device-bottom">
                <div class="iphone-frame">
                  <div class="iphone-island"></div>
                  <div class="iphone-screen">
                    <div class="iphone-stream-bg" style="animation-delay: -3s;"></div>
                    <div class="iphone-stream-lines">
                      <div class="iphone-stream-line" style="width: 70%; opacity: 0.3;"></div>
                      <div class="iphone-stream-line" style="width: 55%; opacity: 0.2;"></div>
                      <div style="margin-top: 4px; height: 32px; border-radius: 4px; background: rgba(255,255,255,0.06);"></div>
                      <div class="iphone-stream-line" style="width: 85%; opacity: 0.15; margin-top: 3px;"></div>
                    </div>
                    <div class="iphone-scanline animate-scanline" style="animation-delay: -2s;"></div>
                    <div class="iphone-live-badge">
                      <span class="iphone-live-dot"></span>
                      <span class="iphone-live-text">LIVE</span>
                    </div>
                    <div class="iphone-latency">38ms</div>
                  </div>
                  <div class="iphone-home-indicator"></div>
                </div>
              </div>
            </div>

          </div>
        </div>
      </div>
    </section>

    <!-- Hero video — vibe coding workflow -->
    <section class="hero-video-section" style="z-index: 10;">
      <div class="hero-video-header">
        <div class="hero-video-eyebrow">Built for vibe coders</div>
        <h2 class="hero-video-title">Prompt. Build. See it live.</h2>
        <p class="hero-video-sub">You're coding with AI — but you can't see the Simulator. SimCast streams it to your browser the moment your app launches.</p>
      </div>
      <div class="hero-video-wrapper animate-fade-in-up delay-300">
        <div class="hero-video-frame">
          <div style="padding:64.88% 0 0 0;position:relative;">
            <iframe
              src="https://player.vimeo.com/video/1184608499?title=0&byline=0&portrait=0"
              style="position:absolute;top:0;left:0;width:100%;height:100%;"
              frameborder="0"
              allow="fullscreen; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
          <script src="https://player.vimeo.com/api/player.js"></script>
        </div>
      </div>
    </section>

    <!-- Demo videos -->
    <section class="demos-section" style="z-index: 10;">
      <div class="demos-header">
        <div class="demos-eyebrow">See it in action</div>
        <h2 class="demos-title">From build to browser in seconds</h2>
      </div>
      <div class="demos-grid">
