  /* ─── Hero ─── */
  .hero {
    position: relative; max-width: 72rem; margin: 0 auto;
    padding: 3rem 1.5rem 3rem;
  }
  @media (min-width: 1024px) { .hero { padding-top: 4rem; } }
  .hero-grid { display: grid; gap: 3rem; align-items: center; }
  @media (min-width: 1024px) { .hero-grid { grid-template-columns: 1fr 520px; gap: 4rem; } }

  .hero-copy { display: flex; flex-direction: column; gap: 2rem; max-width: 36rem; }


  .headline { line-height: 1.05; letter-spacing: -0.025em; font-weight: 800; font-size: clamp(2.8rem, 6vw, 4.5rem); }
  .headline-accent {
    font-family: var(--font-serif); font-style: italic; font-weight: 400;
    background: linear-gradient(135deg, #A07BFF 0%, #00CFFF 60%, #A07BFF 100%);
    background-size: 200% auto;
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtext { font-size: 1.125rem; line-height: 1.75; color: var(--text-2); max-width: 36rem; }

  .cta-row { display: flex; flex-wrap: wrap; align-items: center; gap: 0.75rem; }
  .cta-github {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.75rem 1.5rem; border-radius: 0.75rem;
    font-weight: 600; font-size: 0.875rem;
    background: linear-gradient(135deg, #7B52FF, #5B3FD6);
    color: #fff; border: none;
    text-decoration: none; transition: opacity 0.2s;
    box-shadow: 0 2px 12px rgba(123,82,255,0.35);
  }
  .cta-github:hover { opacity: 0.88; }

  /* ─── Illustration ─── */
  .hero-illustration { display: none; justify-content: center; align-items: center; }
  @media (min-width: 1024px) { .hero-illustration { display: flex; } }

  .illustration-wrapper { position: relative; }
  .illustration-glow {
    position: absolute; inset: -2rem; border-radius: 1.5rem; pointer-events: none;
    background: radial-gradient(ellipse at center, rgba(123,82,255,0.18) 0%, transparent 70%);
  }
  .illustration-inner { position: relative; }

  .browser-chrome {
    border-radius: 1rem; overflow: hidden;
    background: rgba(7,6,26,0.95);
    border: 1px solid rgba(123,82,255,0.2);
    box-shadow: 0 40px 100px rgba(0,0,0,0.75), 0 0 0 1px rgba(123,82,255,0.12), inset 0 1px 0 rgba(255,255,255,0.05);
    width: 600px;
  }

  .tab-bar {
    display: flex; align-items: center; gap: 6px;
    padding: 0.75rem 1rem; border-bottom: 1px solid var(--border-subtle);
    background: rgba(0,0,0,0.3);
  }
  .dot { width: 10px; height: 10px; border-radius: 9999px; }
  .address-bar {
    margin-left: 0.75rem; flex: 1;
    display: flex; align-items: center; gap: 0.5rem;
    padding: 0.25rem 0.75rem; border-radius: 0.375rem;
    background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06);
  }
  .address-dot { width: 8px; height: 8px; border-radius: 9999px; background: rgba(123,82,255,0.5); }
  .address-text { font-size: 10px; font-family: var(--font-mono); color: #8A87B0; }

  .browser-content { padding: 0; display: flex; flex-direction: row; background: rgba(3,2,11,0.6); }
  .panel-left { width: 45%; padding: 0.75rem; display: flex; flex-direction: column; gap: 0.625rem; border-right: 1px solid var(--border-subtle); }
  .panel-right { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 0.75rem; position: relative; background: rgba(0,0,0,0.3); }

  .viewer-row { display: flex; align-items: center; gap: 8px; }

  /* Viewer */
  .viewer-screen {
    position: relative; width: 110px; height: 232px;
    border-radius: 14px; overflow: hidden;
    background: #0a0918;
    border: 1.5px solid rgba(123,82,255,0.3);
    box-shadow: 0 0 20px rgba(123,82,255,0.1);
  }
  .viewer-stream-bg {
    position: absolute; inset: 0;
    background: linear-gradient(160deg,
      rgba(123,82,255,0.15) 0%,
      rgba(0,100,160,0.12) 40%,
      rgba(0,207,255,0.08) 70%,
      rgba(40,10,80,0.14) 100%);
    background-size: 200% 200%;
    animation: stream-shimmer 5s ease-in-out infinite alternate;
  }
  .viewer-app-ui {
    position: absolute; inset: 0;
    display: flex; flex-direction: column;
    padding: 4px;
  }
  .viewer-status-bar {
    display: flex; justify-content: space-between; align-items: center;
    padding: 2px 6px 3px; flex-shrink: 0;
  }
  .viewer-nav-bar {
    padding: 4px 6px 6px; flex-shrink: 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .viewer-content-rows {
    flex: 1; display: flex; flex-direction: column; gap: 4px; padding: 6px;
  }
  .viewer-tab-bar {
    display: flex; justify-content: space-around; align-items: center;
    padding: 4px 8px 6px; flex-shrink: 0;
    border-top: 1px solid rgba(255,255,255,0.06);
  }
  .viewer-scanline {
    position: absolute; left: 0; right: 0; height: 1px; pointer-events: none;
    background: linear-gradient(90deg, transparent, rgba(123,82,255,0.6), rgba(0,207,255,0.6), transparent);
    box-shadow: 0 0 6px rgba(123,82,255,0.4);
  }
  .viewer-label {
    display: flex; align-items: center; gap: 6px;
    margin-top: 6px;
  }
  .viewer-label-name { font-size: 8px; font-weight: 600; color: #EDE9FF; }
  .viewer-label-latency {
    font-size: 7px; font-weight: 600; font-family: var(--font-mono);
    color: rgba(0,207,255,0.9);
    background: rgba(0,207,255,0.08); border: 1px solid rgba(0,207,255,0.2);
    border-radius: 999px; padding: 1px 5px;
  }

  /* Control buttons */
  .ctrl-buttons { display: flex; flex-direction: column; gap: 3px; }
  .ctrl-btn {
    width: 22px; height: 22px;
    border-radius: 5px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    display: flex; align-items: center; justify-content: center;
    color: #8078a8;
  }

  /* Section header */
  .section-header { display: flex; align-items: center; gap: 6px; padding: 0 0.25rem; }
  .section-title { font-size: 8px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: #8078a8; }
  .section-badge {
    font-size: 8px; font-weight: 700; padding: 0px 5px; border-radius: 4px;
    background: rgba(124,58,237,0.18); border: 1px solid rgba(124,58,237,0.25); color: #C4AAFF;
  }
  .section-line { flex: 1; height: 1px; background: var(--border-subtle); }
  .section-uptime { font-size: 8px; color: #8078a8; }

  /* Simulator cards */
  .sim-card { border-radius: 0.75rem; overflow: hidden; transition: all 0.2s; }
  .sim-card-active {
    background: rgba(255,255,255,0.05);
    border: 1px solid #7C3AED;
    box-shadow: 0 0 12px rgba(124,58,237,0.2), 0 0 4px rgba(124,58,237,0.12);
  }
  .sim-card-streaming {
    background: rgba(255,255,255,0.04);
    border: 1px solid transparent;
  }
  .sim-card-inactive {
    background: rgba(255,255,255,0.03);
    border: 1px solid transparent;
  }

  .sim-card-top { display: flex; align-items: flex-start; gap: 0.5rem; padding: 0.625rem 0.625rem 0.5rem; border-bottom: 1px solid var(--border-subtle); }

  .sim-icon-box {
    flex-shrink: 0; width: 32px; height: 32px; border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    background: rgba(124,58,237,0.18); border: 1px solid rgba(124,58,237,0.25);
  }
  .sim-icon-box-inactive {
    background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08);
  }

  .sim-info { flex: 1; min-width: 0; }
  .sim-name-row { display: flex; align-items: center; gap: 5px; margin-bottom: 2px; }
  .sim-name { font-size: 10px; font-weight: 600; color: #EDE9FF; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

  .streaming-badge {
    display: flex; align-items: center; gap: 3px; flex-shrink: 0;
    font-size: 7px; font-weight: 700; letter-spacing: 0.02em;
    padding: 1px 5px; border-radius: 9999px;
    background: rgba(74,222,128,0.1); border: 1px solid rgba(74,222,128,0.2); color: #10B981;
  }
  .streaming-dot { width: 3px; height: 3px; border-radius: 9999px; background: #4ade80; animation: pulse 2s ease-in-out infinite; }

  .watching-badge {
    display: flex; align-items: center; gap: 3px; flex-shrink: 0;
    font-size: 7px; font-weight: 700; letter-spacing: 0.02em;
    padding: 1px 5px; border-radius: 9999px;
    background: rgba(124,58,237,0.15); border: 1px solid rgba(124,58,237,0.3); color: #7C3AED;
  }

  .sim-os { font-size: 8px; color: #8A87B0; margin: 0; }
  .sim-udid { font-size: 7px; font-family: var(--font-mono); letter-spacing: 0.06em; color: #8078a8; margin: 2px 0 0; }

  /* Card footer */
  .sim-card-footer { display: flex; align-items: center; justify-content: space-between; padding: 0.375rem 0.625rem; }
  .sim-duration { font-size: 7px; color: #8078a8; }
  .sim-actions { display: flex; align-items: center; gap: 6px; }

  .sim-watch-hint {
    display: flex; align-items: center; gap: 3px;
    font-size: 7px; color: #8078a8;
  }

  .sim-btn {
    display: flex; align-items: center; gap: 3px;
    padding: 2px 8px; border-radius: 6px;
    font-size: 8px; font-weight: 600;
  }
  .sim-btn-danger {
    background: rgba(248,113,113,0.12); border: 1px solid rgba(248,113,113,0.2); color: #f87171;
  }
  .sim-btn-primary {
    background: rgba(124,58,237,0.2); border: 1px solid rgba(124,58,237,0.3); color: #C4AAFF;
  }

  .scan-line {
    position: absolute; left: 0; right: 0; height: 1px; pointer-events: none;
    background: linear-gradient(90deg, transparent, rgba(123,82,255,0.8), rgba(0,207,255,0.8), transparent);
    box-shadow: 0 0 8px rgba(123,82,255,0.6);
  }

  .macos-pill {
    position: absolute; right: -2.5rem; bottom: 2rem;
    display: flex; align-items: center; gap: 0.625rem;
    padding: 0.5rem 0.75rem; border-radius: 0.75rem;
    background: rgba(7,6,26,0.9); border: 1px solid rgba(255,255,255,0.08);
    box-shadow: 0 8px 32px rgba(0,0,0,0.5); backdrop-filter: blur(8px);
  }
  .macos-pill-icon {
    width: 24px; height: 24px; border-radius: 0.375rem; flex-shrink: 0;
    background: linear-gradient(135deg, #7B52FF, #00CFFF);
    display: flex; align-items: center; justify-content: center;
  }
  .macos-pill-icon svg { width: 14px; height: 14px; }
  .macos-pill-title { font-size: 10px; font-weight: 600; color: #EDE9FF; }
  .macos-pill-sub { font-size: 9px; color: #8A87B0; }

  .webrtc-badge {
    position: absolute; right: -1.5rem; top: 15%;
    display: flex; align-items: center; gap: 6px;
    padding: 6px 10px; border-radius: 0.75rem;
    background: rgba(7,6,26,0.9); border: 1px solid rgba(0,207,255,0.15);
    box-shadow: 0 4px 20px rgba(0,0,0,0.4); backdrop-filter: blur(8px);
  }
  .webrtc-dot { width: 6px; height: 6px; border-radius: 9999px; background: #22d3ee; animation: pulse 2s ease-in-out infinite; }
  .webrtc-text { font-size: 10px; font-weight: 500; color: #00CFFF; }

  /* ─── iPhone stream device ─── */

  @keyframes stream-shimmer {
    0%   { background-position: -200% 0; }
    100% { background-position: 200% 0; }
  }
  @keyframes iphone-float {
    0%, 100% { transform: rotateX(-2deg) rotateY(12deg) translateY(0px); }
    50%       { transform: rotateX(-2deg) rotateY(12deg) translateY(-10px); }
  }
  @keyframes live-pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.4; }
  }

  /* Stacked devices */
  .devices-stack {
    position: absolute;
    left: -5.5rem;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 88px;
    height: 188px;
  }
  .stacked-device {
    position: absolute;
    left: 0;
  }
  .stacked-device-bottom {
    top: 30px;
    left: 36px;
    transform: rotate(2deg);
    z-index: 1;
    animation: iphone-float 7s ease-in-out 2.4s infinite;
  }
  .stacked-device-bottom .iphone-frame {
    opacity: 0.65;
    border-color: rgba(123,82,255,0.2);
  }
  .stacked-device-top {
    top: -60px;
    transform: rotate(-1.5deg);
    z-index: 2;
    animation: iphone-float 7s ease-in-out 1.2s infinite;
  }

  .iphone-device {
    position: absolute;
    left: -5rem;
    top: 44%;
    transform: translateY(-50%);
    perspective: 900px;
    z-index: 10;
    display: none;
  }

  .iphone-frame {
    width: 88px;
    height: 188px;
    border-radius: 22px;
    background: linear-gradient(160deg, #1c1a2e 0%, #0e0d1f 60%, #18162d 100%);
    border: 2px solid rgba(123,82,255,0.45);
    box-shadow:
      0 0 0 1px rgba(255,255,255,0.06),
      0 20px 50px rgba(0,0,0,0.7),
      0 0 30px rgba(123,82,255,0.2),
      inset 0 1px 0 rgba(255,255,255,0.08);
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 14px 5px 8px;
    animation: iphone-float 7s ease-in-out 1.2s infinite;
  }

  .iphone-island {
    width: 28px; height: 8px;
    border-radius: 999px;
    background: #000;
    margin-bottom: 6px;
    flex-shrink: 0;
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.04);
  }

  .iphone-screen {
    flex: 1;
    width: 100%;
    border-radius: 10px;
    overflow: hidden;
    position: relative;
    background: #050410;
  }

  .iphone-stream-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      160deg,
      rgba(123,82,255,0.22) 0%,
      rgba(0,100,160,0.18) 40%,
      rgba(0,207,255,0.12) 70%,
      rgba(40,10,80,0.2) 100%
    );
    background-size: 200% 200%;
    animation: stream-shimmer 5s ease-in-out infinite alternate;
  }

  .iphone-stream-lines {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding: 16px 8px 8px;
  }

  .iphone-stream-line {
    height: 5px;
    border-radius: 999px;
    background: rgba(255,255,255,0.18);
  }

  .iphone-stream-app-bar {
    margin-top: auto;
    height: 22px;
    border-radius: 6px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.06);
    width: 100%;
  }

  .iphone-scanline {
    position: absolute;
    left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(0,207,255,0.5), transparent);
    pointer-events: none;
  }

  .iphone-live-badge {
    position: absolute;
    top: 7px; right: 6px;
    display: flex; align-items: center; gap: 3px;
    background: rgba(220,38,38,0.85);
    border-radius: 999px;
    padding: 2px 5px;
    backdrop-filter: blur(4px);
  }

  .iphone-live-dot {
    width: 4px; height: 4px;
    border-radius: 50%;
    background: #fff;
    animation: live-pulse 1.4s ease-in-out infinite;
  }

  .iphone-live-text {
    font-size: 6px;
    font-weight: 700;
    color: #fff;
    letter-spacing: 0.05em;
  }

  .iphone-latency {
    position: absolute;
    bottom: 7px; left: 6px;
    font-size: 6px;
    font-weight: 600;
    color: rgba(0,207,255,0.9);
    background: rgba(0,207,255,0.08);
    border: 1px solid rgba(0,207,255,0.2);
    border-radius: 999px;
    padding: 1px 5px;
  }

  .iphone-home-indicator {
    width: 28px; height: 3px;
    border-radius: 999px;
    background: rgba(255,255,255,0.2);
    margin-top: 5px;
    flex-shrink: 0;
  }

  /* ─── Demos ─── */
  /* ─── Hero Video ─── */
  .hero-video-section {
    position: relative; max-width: 72rem; margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }
  .hero-video-header { text-align: center; margin-bottom: 2.5rem; }
  .hero-video-eyebrow {
    font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em;
    color: var(--violet-2); margin-bottom: 0.75rem;
  }
  .hero-video-title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem); font-weight: 700;
    color: var(--text); line-height: 1.3; margin-bottom: 0.75rem;
  }
  .hero-video-sub {
    font-size: 1rem; color: var(--text-2); line-height: 1.6;
    max-width: 36rem; margin: 0 auto;
  }
  .hero-video-wrapper {
    max-width: 56rem; margin: 0 auto;
  }
  .hero-video-frame {
    position: relative; width: 100%;
    overflow: hidden;
    border-radius: 1rem;
    border: 1px solid var(--border-subtle);
    box-shadow: 0 0 60px rgba(123,82,255,0.12), 0 0 120px rgba(123,82,255,0.06);
  }
  .hero-video-frame iframe {
    border: none;
  }

  /* ─── Demo Videos ─── */
  .demos-section {
    position: relative; max-width: 72rem; margin: 0 auto;
    padding: 4rem 1.5rem 2rem;
  }
  .demos-header { text-align: center; margin-bottom: 3rem; }
  .demos-eyebrow {
    font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em;
    color: var(--violet-2); margin-bottom: 0.75rem;
  }
  .demos-title {
    font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 700;
    color: var(--text); line-height: 1.3;
  }
  .demos-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;
  }
  @media (max-width: 768px) {
    .demos-grid { grid-template-columns: 1fr; }
  }
  .demo-card {
    border-radius: 1rem; overflow: hidden;
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--border-subtle);
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .demo-card:hover {
    border-color: rgba(123,82,255,0.3);
    box-shadow: 0 0 24px rgba(123,82,255,0.08);
  }
  .demo-video-frame {
    position: relative; width: 100%; aspect-ratio: 16 / 10;
    background: rgba(0,0,0,0.4); overflow: hidden;
  }
  .demo-video {
    position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;
  }
  .demo-embed {
    position: absolute; inset: 0; width: 100%; height: 100%; border: 0;
  }
  .demo-video-placeholder {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    background: linear-gradient(160deg, rgba(123,82,255,0.08) 0%, rgba(0,207,255,0.04) 100%);
  }
  .demo-video:not([src=""]) + .demo-video-placeholder { display: none; }
  .demo-label {
    font-size: 0.9375rem; font-weight: 600; color: var(--text);
    padding: 1rem 1rem 0.25rem;
  }
  .demo-desc {
    font-size: 0.8125rem; color: var(--text-2); line-height: 1.5;
    padding: 0 1rem 1rem;
  }

  /* ─── Features ─── */
  .features-section {
    position: relative; max-width: 72rem; margin: 0 auto;
    padding: 3rem 1.5rem;   }
  .features-header { text-align: center; margin-bottom: 3.5rem; }
  .features-eyebrow {
    display: inline-block; margin-bottom: 0.75rem;
    font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--violet-2);
  }
  .features-title { font-weight: 700; letter-spacing: -0.025em; margin-bottom: 0.75rem; font-size: clamp(1.75rem, 4vw, 2.5rem); }
  .features-sub { color: var(--text-2); font-size: 1rem; }

  .features-grid { display: grid; gap: 1rem; }
  @media (min-width: 640px) { .features-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .features-grid { grid-template-columns: repeat(3, 1fr); } }

  .feature-card { border-radius: 1rem; padding: 1.25rem; transition: all 0.2s; }
  .feature-card-header { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem; }
  .feature-icon {
    width: 2rem; height: 2rem; border-radius: 0.5rem;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    background: rgba(123,82,255,0.12); color: #A07BFF;
  }
  .feature-title { font-weight: 600; font-size: 0.875rem; color: var(--text); }
  .feature-desc { font-size: 0.875rem; line-height: 1.625; color: var(--text-2); }

  /* ─── Agents section ─── */
  /* ─── Integrations ─── */
  .integrations-section {
    position: relative; max-width: 72rem; margin: 0 auto;
    padding: 3rem 1.5rem;   }
  .integrations-header { text-align: center; margin-bottom: 3.5rem; }
  .integrations-eyebrow {
    display: inline-block; margin-bottom: 0.75rem;
    font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--violet-2);
  }
